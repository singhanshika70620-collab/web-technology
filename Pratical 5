<!DOCTYPE html>
<html>
<head>
<title>Supermarket</title>

<style>
body {
    background-color: #f5f5dc;
    font-family: Arial;
}

h1 {
    color: green;
    text-align: center;
}

h2 {
    color: brown;
}

ul {
    background-color: white;
    padding: 10px;
    width: 200px;
}

li {
    color: black;
    font-size: 18px;
}

.offer {
    color: red;
    font-weight: bold;
}
</style>

</head>

<body>

<h1>Welcome to My Supermarket</h1>

<h2>Grocery Items</h2>
<ul>
<li>Rice</li>
<li>Wheat</li>
<li>Oil</li>
<li>Sugar</li>
</ul>

<h2>Dairy Products</h2>
<ul>
<li>Milk</li>
<li>Butter</li>
<li>Cheese</li>
</ul>

<h2>Offers</h2>
<p class="offer">Get 20% discount on all items!</p>

</body>
</html>
